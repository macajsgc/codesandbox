# Servidor de Acceso a Nodos de Red (RPC Endpoint)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Clave Privada en formato Array de bytes para el despliegue
SOLANA_PRIVATE_KEY=[TU_CLAVE_PRIVADA_AQUÍ]

# Direcciones Base de Activos Verificados
MINT_ADDRESS_JUP=JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN
DECIMALS_JUP=6
const { Connection, PublicKey, Keypair } = require('@solana/web3.js');
const { getAccount, getAssociatedTokenAddress } = require('@solana/spl-token');
require('dotenv').config();

async function inicializarControlTesoria() {
    const rpcUrl = process.env.SOLANA_RPC_URL || "https://api.devnet.solana.com";
    const conexion = new Connection(rpcUrl, 'confirmed');
    console.log(`[CONEXIÓN] Enlazado al nodo: ${rpcUrl}`);

    if (!process.env.SOLANA_PRIVATE_KEY) {
        console.error("[ERROR] Variable SOLANA_PRIVATE_KEY ausente.");
        return;
    }
    
    try {
        const claveSecretaBytes = Uint8Array.from(JSON.parse(process.env.SOLANA_PRIVATE_KEY));
        const operadorKeypair = Keypair.fromSecretKey(claveSecretaBytes);
        const billeteraPublica = operadorKeypair.publicKey;
        
        const tokenMintJUP = new PublicKey(process.env.MINT_ADDRESS_JUP || "JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN");
        const decimalesJUP = parseInt(process.env.DECIMALS_JUP) || 6;

        const direccionAsociadaToken = await getAssociatedTokenAddress(tokenMintJUP, billeteraPublica);
        const informacionCuenta = await getAccount(conexion, direccionAsociadaToken);
        
        const balanceReal = Number(informacionCuenta.amount) / Math.pow(10, decimalesJUP);

        console.log("\n==================================================");
        console.log(`Balance Registrado: ${balanceReal.toFixed(decimalesJUP)} JUP`);
        console.log("==================================================\n");
    } catch (error) {
        console.error("[ERROR OPERATIVO]", error);
    }
}

inicializarControlTesoria();
